#geom_point() +
labs(
x = "n^2",
y = "Tempo medio di esecuzione",
color = "Tipo esecuzione",
title = "Confronto tempi seriale vs p1 vs p2 vs p3; theta = 0.1"
) +
theme_minimal(base_size = 14) # tema pulito
